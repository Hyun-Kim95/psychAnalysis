# Canonical site URL (no trailing slash). Used for OG tags, canonical, sitemap, robots.
# VITE_SITE_ORIGIN=https://www.example.com

# API base URL. Production: e.g. your Railway API origin (no trailing slash).
# Local `npm run dev`: leave unset — Vite proxies /api → http://localhost:8080.
# (localhost/127.0.0.1 URLs in .env are ignored during dev so the proxy is always used.)
# VITE_API_URL=

# Optional: public inquiry form (e.g. Google Forms), shown on /info
# VITE_CONTACT_FORM_URL=

# Optional: contact email for mailto link on /info
# VITE_CONTACT_EMAIL=

# Optional: donation / sponsorship page (Ko-fi, GitHub Sponsors, etc.)
# VITE_DONATION_URL=
